/**
 * Exemplos de requisições HTTP para testar a API
 * Salve este arquivo e importe em um cliente HTTP (Postman, Insomnia, etc)
 */

// ============================================
// IMERSÕES
// ============================================

/**
 * 1. CRIAR IMERSÃO
 * POST http://localhost:3000/api/immersions
 */
{
  "name": "Imersão de Verão 2026",
  "description": "Uma semana intensiva de aprendizado",
  "data": "2026-07-15",
  "local": "Guarujá, SP",
  "qtd_lote": 3
}

/**
 * 2. LISTAR TODAS AS IMERSÕES
 * GET http://localhost:3000/api/immersions
 * Query params opcionais: ?limit=10&offset=0
 */

/**
 * 3. LISTAR IMERSÕES ATIVAS
 * GET http://localhost:3000/api/immersions/active
 */

/**
 * 4. OBTER IMERSÃO ESPECÍFICA
 * GET http://localhost:3000/api/immersions/1
 */

/**
 * 5. OBTER IMERSÃO COM SEUS LOTES
 * GET http://localhost:3000/api/immersions/1/with-lots
 */

/**
 * 6. ATUALIZAR IMERSÃO
 * PUT http://localhost:3000/api/immersions/1
 */
{
  "name": "Imersão de Verão 2026 - Edição Especial",
  "valor": 5500.00,
  "local": "Praia Grande, SP"
}

/**
 * 7. DELETAR IMERSÃO
 * DELETE http://localhost:3000/api/immersions/1
 */


// ============================================
// LOTES
// ============================================

/**
 * 1. CRIAR LOTE
 * POST http://localhost:3000/api/lots
 */
{
  "id_immersion": 1,
  "lote_number": 1,
  "valor": 4500.00,
  "quantity_available": 50,
  "data_inicio": "2026-06-01",
  "data_fim": "2026-06-15"
}

/**
 * 2. LISTAR TODOS OS LOTES
 * GET http://localhost:3000/api/lots
 * Query params opcionais: ?limit=20&offset=0
 */

/**
 * 3. OBTER LOTES DE UMA IMERSÃO
 * GET http://localhost:3000/api/lots/immersion/1
 */

/**
 * 4. OBTER LOTE ATIVO DA IMERSÃO (importante!)
 * GET http://localhost:3000/api/immersions/1/active-lot
 * Este endpoint automaticamente:
 * - Se hoje está entre data_inicio e data_fim: retorna este lote
 * - Se hoje > data_fim: retorna o próximo lote
 * - Se não houver lote ativo: retorna 404
 */

/**
 * 5. OBTER LOTES PRÓXIMOS DE EXPIRAR
 * GET http://localhost:3000/api/lots/upcoming-expiry?days=7
 * Query params:
 * - days: número de dias para considerar (default: 7)
 */

/**
 * 6. OBTER LOTES EXPIRADOS
 * GET http://localhost:3000/api/lots/expired
 */

/**
 * 7. OBTER LOTE ESPECÍFICO
 * GET http://localhost:3000/api/lots/1
 */

/**
 * 8. COMPRAR LUGARES (decrementar quantidade)
 * POST http://localhost:3000/api/lots/1/buy
 */
{
  "quantity": 2
}

/**
 * 9. ADICIONAR LUGARES (cancelamento/devolução)
 * POST http://localhost:3000/api/lots/1/add-quantity
 */
{
  "quantity": 1
}

/**
 * 10. ATUALIZAR LOTE
 * PUT http://localhost:3000/api/lots/1
 */
{
  "valor": 4800.00,
  "quantity_available": 45,
  "data_fim": "2026-06-20"
}

/**
 * 11. DELETAR LOTE
 * DELETE http://localhost:3000/api/lots/1
 */


// ============================================
// FLUXO RECOMENDADO DE TESTES
// ============================================

/*
1. Criar uma imersão
   POST /api/immersions

2. Criar lotes para a imersão (pelo menos 2)
   POST /api/lots
   POST /api/lots

3. Consultar o lote ativo
   GET /api/immersions/1/active-lot

4. Comprar alguns lugares no lote ativo
   POST /api/lots/1/buy

5. Verificar quantidade disponível
   GET /api/lots/1

6. Obter todos os lotes da imersão
   GET /api/lots/immersion/1

7. Obter imersão com seus lotes
   GET /api/immersions/1/with-lots

8. Simular vencimento alterando data_fim para ontem
   PUT /api/lots/1
   { "data_fim": "2026-05-29" }

9. Consultar lote ativo novamente (deve retornar o próximo)
   GET /api/immersions/1/active-lot

10. Ver lotes próximos de expirar
    GET /api/lots/upcoming-expiry?days=30

11. Atualizar imersão
    PUT /api/immersions/1

12. Deletar dados de teste
    DELETE /api/immersions/1
    (Isso também deleta todos os lotes associados)
*/
